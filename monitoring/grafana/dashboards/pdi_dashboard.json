{
  "uid": "pdi-risk-monitoring",
  "title": "PDI - Risk Monitoring Dashboard",
  "tags": ["pdi", "risk", "delinquency"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Total Customers",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as total FROM customers",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"steps": [{"color": "blue", "value": 0}]}
        }
      }
    },
    {
      "id": 2,
      "title": "Critical Customers",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FROM risk_scores WHERE risk_tier = 'critical'",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "thresholds": {"steps": [{"color": "red", "value": 0}]}
        }
      }
    },
    {
      "id": 3,
      "title": "Average Risk Score",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [
        {
          "rawSql": "SELECT AVG(risk_score)::numeric(5,3) FROM risk_scores",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.3},
              {"color": "orange", "value": 0.5},
              {"color": "red", "value": 0.7}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Scoring Volume (Last 24h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FROM risk_scores WHERE scored_at >= NOW() - INTERVAL '24 hours'",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "id": 5,
      "title": "Interventions Sent",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FROM interventions",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "title": "Drift Alerts",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FROM drift_logs WHERE drift_detected = true",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Risk Score Distribution Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "rawSql": "SELECT date_trunc('hour', scored_at) as time, risk_tier, COUNT(*) as count FROM risk_scores GROUP BY 1, 2 ORDER BY 1",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 8,
      "title": "Risk by Region",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "rawSql": "SELECT c.region, rs.risk_tier, COUNT(*) as count FROM risk_scores rs JOIN customers c ON rs.customer_id = c.customer_id GROUP BY c.region, rs.risk_tier ORDER BY c.region",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "id": 9,
      "title": "Model Scores Comparison (XGBoost vs Ensemble)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "rawSql": "SELECT scored_at as time, AVG(xgboost_score)::numeric(5,3) as xgboost_avg, AVG(ensemble_score)::numeric(5,3) as ensemble_avg FROM risk_scores WHERE scored_at >= NOW() - INTERVAL '7 days' GROUP BY date_trunc('hour', scored_at), scored_at ORDER BY scored_at",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 10,
      "title": "Top 10 Highest Risk Customers",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "rawSql": "SELECT rs.customer_id, c.first_name || ' ' || c.last_name as name, rs.risk_score::numeric(5,3), rs.risk_tier, rs.credit_score_mapped, rs.scored_at FROM risk_scores rs JOIN customers c ON rs.customer_id = c.customer_id ORDER BY rs.risk_score DESC LIMIT 10",
          "refId": "A",
          "format": "table"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"}
}
