# ============================================================
# Pre-Delinquency Intervention Engine - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   copy .env.example .env

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pdi_user
POSTGRES_PASSWORD=pdi_password
POSTGRES_DB=pdi_db

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_INTERNAL_BOOTSTRAP_SERVERS=kafka:29092

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Apache Flink
FLINK_JOBMANAGER_HOST=localhost
FLINK_JOBMANAGER_PORT=8081

# Apache Spark
SPARK_MASTER_URL=spark://localhost:7077
SPARK_MASTER_WEBUI=http://localhost:8082

# Feature Store (Feast)
FEAST_REPO_PATH=./feature_store/feature_repo

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=pdi_delinquency_prediction

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Scoring Service
SCORING_SERVICE_HOST=0.0.0.0
SCORING_SERVICE_PORT=8000

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050
DASHBOARD_DEBUG=True

# Model Config
XGBOOST_WEIGHT=0.6
LSTM_WEIGHT=0.4
RISK_CRITICAL_THRESHOLD=0.7
RISK_WATCH_THRESHOLD=0.5
COOLDOWN_DAYS=7

# Data Generation
NUM_CUSTOMERS=1000
TRANSACTION_MONTHS=6
STRESS_CUSTOMER_PCT=0.20

# GenAI (Groq) - Get key from https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Airflow
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLt0nIe3aU=

# ─────────────────────────────────────────────
# Notification Dispatcher (Production Channels)
# ─────────────────────────────────────────────

# Email (SMTP) — Use Gmail App Password or SendGrid SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=Barclays India - Financial Wellness
SMTP_FROM_EMAIL=your-email@gmail.com

# SMS & WhatsApp (Twilio) — Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Webhooks (optional — for push notifications, CRM, collections)
WEBHOOK_PUSH_URL=
WEBHOOK_CRM_URL=
WEBHOOK_COLLECTIONS_URL=
