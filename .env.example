# ============================================================
# PDI Engine — Environment Variables Template
# Copy this file to .env and fill in all values.
# NEVER commit .env to git.
# In production, these are injected from Azure Key Vault.
# ============================================================

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=pdi_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=pdi_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer   # set to 'require' in production

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_TLS_ENABLED=false    # set to 'true' in production
REDIS_KEY_SECRET=CHANGE_ME_redis_hmac_key

# ─── JWT Authentication ───────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── PII Encryption ──────────────────────────────────────
# Generate with: python -c "from config.encryption import generate_encryption_key; print(generate_encryption_key())"
PII_ENCRYPTION_KEY=CHANGE_ME_generate_with_fernet
AUDIT_HASH_SALT=CHANGE_ME_random_salt

# ─── CORS ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8050

# ─── Airflow ──────────────────────────────────────────────
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME_generate_fernet_key
AIRFLOW_WEBSERVER_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_airflow_password

# ─── Grafana ──────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ─── Superset ─────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
SUPERSET_SECRET_KEY=CHANGE_ME_superset_secret_key

# ─── N8N ──────────────────────────────────────────────────
N8N_ADMIN_USER=admin
N8N_ADMIN_PASSWORD=CHANGE_ME_n8n_password

# ─── Twilio (SMS / WhatsApp) ──────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TEST_PHONE_TO=+91xxxxxxxxxx

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=CHANGE_ME_app_password

# ─── LLM (Groq) ───────────────────────────────────────────
GROQ_API_KEY=CHANGE_ME

# ─── PDI Environment ──────────────────────────────────────
PDI_ENV=development   # set to 'production' to enforce required secrets
